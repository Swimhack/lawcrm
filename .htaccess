RewriteEngine On

# Protect sensitive files
<FilesMatch "^\.env$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Route API requests
RewriteRule ^api/(.*)$ api/router.php?route=$1 [QSA,L]

# Deny direct access to includes and config
RewriteRule ^config/ - [F,L]
RewriteRule ^includes/ - [F,L]
RewriteRule ^migrations/ - [F,L]
